# Shared environment template for the team baseline.
# Keep SQL Server local for now. Delta Lake will be added later if the team approves it.

PROJECT_NAME=project_nhom19_datalakehouse

INGESTION_MODE=sample
YOUTUBE_API_KEY=
YOUTUBE_VIDEO_ID=
YOUTUBE_ORDER=time
YOUTUBE_MAX_RESULTS=100
YOUTUBE_PAGE_LIMIT=5
YOUTUBE_RETRY_DELAY_SECONDS=5
YOUTUBE_PUBLISH_DELAY_MS=0

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=youtube-comments
REPLAY_DELAY_MS=300
SAMPLE_LOOP=false
KAFKA_RETRY_DELAY_SECONDS=5

HDFS_URI=hdfs://namenode:8020
HDFS_BASE_PATH=/lake
BRONZE_PATH=/lake/bronze
SILVER_PATH=/lake/silver
GOLD_PATH=/lake/gold
SPARK_MASTER_URL=spark://spark-master:7077
SENTIMENT_MODE=transformer
SENTIMENT_MODEL_NAME=cardiffnlp/twitter-xlm-roberta-base-sentiment-multilingual
SENTIMENT_BATCH_SIZE=8
SENTIMENT_MAX_LENGTH=256
SENTIMENT_FALLBACK_TO_KEYWORD=true

METASTORE_DB_NAME=hive_metastore
SQLSERVER_HOST=host.docker.internal
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=hive_metastore
SQLSERVER_USERNAME=sa
SQLSERVER_PASSWORD=YourStrongPassword123!
METASTORE_THRIFT_PORT=9083
METASTORE_WAREHOUSE_DIR=hdfs://namenode:8020/user/hive/warehouse
